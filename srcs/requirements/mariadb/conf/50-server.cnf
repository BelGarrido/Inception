[server]

[mysqld]
# --- User and Runtime Paths ---
# System user used by the MariaDB process.
user                    = mysql
# PID file used to track the running MariaDB process.
pid-file                = /run/mysqld/mysqld.pid
# Unix socket for local connections inside the container.
socket                  = /run/mysqld/mysqld.sock
# MariaDB installation base directory.
basedir                 = /usr
# Directory where database files are stored (persistent volume).
datadir                 = /var/lib/mysql
# Temporary directory for runtime operations.
tmpdir                  = /tmp
# Location of MariaDB language/message files.
lc-messages-dir         = /usr/share/mysql

# --- Network and Port ---
# Listen on all interfaces so the WordPress container can connect over Docker network.
bind-address            = 0.0.0.0
# Default MariaDB port.
port                    = 3306

# --- Error Logging ---
# Error log file for startup and runtime diagnostics.
log_error = /var/log/mysql/error.log

# --- Character Set ---
# UTF-8 compatible character set for full Unicode support.
character-set-server  = utf8mb4
# Default collation paired with utf8mb4.
collation-server      = utf8mb4_general_ci

[embedded]
[mariadb]
[mariadb-10.5]

# -----------------------------------------------------------------------------
# MariaDB configuration summary:
# -----------------------------------------------------------------------------
# Purpose:
# - Configure MariaDB server paths, networking, and defaults inside the container.
# - Allow access from the WordPress container through the Docker network.
# - Set UTF-8 compatible defaults for WordPress data.
#
# Why bind-address 0.0.0.0:
# - Containers communicate over an internal Docker bridge network.
# - Binding only to 127.0.0.1 would block external container connections.
#
# Related files:
# - Database bootstrap and user/database creation are handled in tools/setup.sh.
# - Service and volume wiring are defined in srcs/docker-compose.yml.
